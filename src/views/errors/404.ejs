<%- include('../partials/header') %>
<main>
    <h1 class="error">Page Not Found</h1>
    <p class="error">The page you are looking for does not exist.</p>
    <img class="error" src="/images/404.avif" alt="404 Not Found">
    <p class="error">Return to the <a href="/">homepage</a> to continue browsing.</p>
    <% if (NODE_ENV === 'development') { %>
        <details open>
            <summary>Error Details (Development Only)</summary>
            <pre><%= error %></pre>
            <pre><%= stack %></pre>
        </details>
    <% } %>
</main>
<%- include('../partials/footer') %>
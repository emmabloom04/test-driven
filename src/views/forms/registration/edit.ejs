<%- include('../../partials/header') %>

<main>
  <h1><%= title %></h1>

    <form method="POST" action="/register/<%= user.id %>/edit" class="edit-form">
        <div class="form-group">
            <label for="name">Name:</label>
            <input
            type="text"
            id="name"
            name="name"
            value="<%= user.name || '' %>"
            required
            />
        </div>

        <div class="form-group">
            <label for="email">Email:</label>
            <input
            type="email"
            id="email"
            name="email"
            value="<%= user.email || '' %>"
            required
            />
        </div>

        <div class="edit-actions">
            <button type="submit">Update Account</button>
            <a href="/">Cancel</a>
        </div>
    </form>
    <form method="POST" action="/register/<%= user.id %>/delete" style="display: inline;">
        <button type="submit" onclick="return confirm('Are you sure you want to delete your account?')">Delete</button>
    </form>
  <div>
    <a href=""></a>
  </div>
</main>

<%- include('../../partials/footer') %>

<%- include('../../partials/header') %>
<main>
    <h1>Sell A Car</h1>
    <p>Our team is still working on developing this page.</p>
    <form method="POST" action="/cars" class="sell-a-car-form">
        <div class="form-group">
            <label for="vin">Vin Number</label>
            <input 
            type="text"
            id="vin"
            name="vin"
            minlength="17"
            maxlength="17"
            size="17"
            placeholder="Vin Number"
            required
            />
        </div>

        <div class="form-group">
            <label for="make">Make</label>
            <input 
            type="text"
            id="make"
            name="make"
            maxlength="20"
            placeholder="Make"
            required
            />
        </div>

        <div class="form-group">
            <label for="model">Model</label>
            <input 
            type="text"
            id="model"
            name="model"
            maxlength="20"
            placeholder="Make"
            required
            />
        </div>

        <div class="form-group">
            <label for="category">Category</label>
            <select name="category" id="category">
                <!-- we'll build it so that it pulls from categories table rather than being hard coded -->
                <option value="1">Sedan</option>
                <option value="2">SUV</option>
                <option value="3">Minivan</option>
            </select>
        </div>

        <button type="submit"></button>
    </form>
</main>
<%- include('../../partials/footer') %>